#!/usr/bin/env python3
"""Full-text search across Claude Code sessions using ripgrep."""

import argparse
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path

CLAUDE_PROJECTS = Path.home() / ".claude" / "projects"


def extract_text(msg):
    """Extract plain text from a Claude message object.

    Only extracts 'text' type parts — tool_result items are skipped.
    """
    if isinstance(msg, dict) and "content" in msg:
        content = msg["content"]
        if isinstance(content, str):
            return content.strip()
        if isinstance(content, list):
            parts = []
            for c in content:
                if isinstance(c, dict) and c.get("type") == "text":
                    parts.append(c["text"])
            return " ".join(parts).strip()
    return ""


def snippet_around_match(text, query, width=120):
    """Return a ~width-char window centered on the first occurrence of query.

    If the match is near the start or end, the window shifts accordingly.
    """
    lower_text = text.lower()
    lower_query = query.lower()
    idx = lower_text.find(lower_query)
    if idx == -1:
        return text[:width]

    # Center the window on the match
    half = (width - len(query)) // 2
    start = max(0, idx - half)
    end = start + width

    # Shift if we'd go past the end
    if end > len(text):
        end = len(text)
        start = max(0, end - width)

    snippet = text[start:end].replace("\n", " ").replace("\t", " ").strip()

    prefix = "..." if start > 0 else ""
    suffix = "..." if end < len(text) else ""
    return f"{prefix}{snippet}{suffix}"


def extract_matches(matched_files, query, project_filter=None):
    """Parse matched JSONL files and extract session metadata + matching snippets.

    Returns a list of dicts sorted by timestamp (newest first), one per session.
    """
    sessions = []

    for jsonl_path in matched_files:
        session_id = os.path.basename(jsonl_path).replace(".jsonl", "")
        proj_dir = os.path.basename(os.path.dirname(jsonl_path))

        slug = None
        ts = None
        cwd = None
        first_match_snippet = None

        try:
            with open(jsonl_path) as f:
                for line in f:
                    try:
                        d = json.loads(line.strip())
                    except (json.JSONDecodeError, ValueError):
                        continue

                    if "slug" in d and not slug:
                        slug = d["slug"]
                    if "timestamp" in d and not ts:
                        ts = d["timestamp"]
                    if "cwd" in d and not cwd:
                        cwd = d["cwd"]

                    if d.get("type") == "user" and "message" in d:
                        text = extract_text(d["message"])
                        if text and query.lower() in text.lower():
                            if not first_match_snippet:
                                first_match_snippet = snippet_around_match(
                                    text, query
                                )
        except (OSError, IOError):
            continue

        if not first_match_snippet:
            continue

        # Apply project filter
        if project_filter and cwd:
            if project_filter not in cwd:
                continue

        sessions.append(
            {
                "id": session_id,
                "proj_dir": proj_dir,
                "slug": slug or "",
                "ts": ts[:10] if ts else "?",
                "cwd": cwd or "?",
                "snippet": first_match_snippet,
            }
        )

    return sorted(sessions, key=lambda s: s["ts"], reverse=True)


def find_preview_script():
    """Locate the claude-sessions script for preview delegation.

    Returns the absolute path, or None if not found.
    """
    # Try PATH first
    path = shutil.which("claude-sessions")
    if path:
        return path
    # Fallback to known location
    fallback = Path.home() / ".local" / "bin" / "claude-sessions"
    if fallback.exists():
        return str(fallback)
    return None


def check_dependencies():
    """Verify rg, fzf, and claude are available on PATH."""
    missing = []
    if not shutil.which("rg"):
        missing.append("rg (ripgrep) not found. Install: brew install ripgrep")
    if not shutil.which("fzf"):
        missing.append("fzf not found. Install: brew install fzf")
    if not shutil.which("claude"):
        missing.append("claude not found on PATH")
    if missing:
        for m in missing:
            print(m, file=sys.stderr)
        sys.exit(1)


def parse_args():
    """Parse CLI arguments: positional query and optional -p flag."""
    parser = argparse.ArgumentParser(
        prog="claude-search",
        description="Full-text search across Claude Code sessions.",
        usage="claude-search <query> [-p]",
    )
    parser.add_argument("query", help="Search term (literal string, case-insensitive)")
    parser.add_argument(
        "-p",
        "--project",
        action="store_true",
        help="Filter to sessions from the current working directory only",
    )
    return parser.parse_args()


def rg_find_sessions(query):
    """Use ripgrep to find session JSONL files containing the query.

    Returns a list of absolute file paths.
    Uses -F (fixed-string), -i (case-insensitive), -l (files-with-matches).
    """
    try:
        result = subprocess.run(
            ["rg", "-Fil", query, "--glob", "*.jsonl", str(CLAUDE_PROJECTS)],
            capture_output=True,
            text=True,
            timeout=30,
        )
    except FileNotFoundError:
        print("rg (ripgrep) not found. Install: brew install ripgrep", file=sys.stderr)
        sys.exit(1)

    if result.returncode == 1:
        # No matches
        return []
    if result.returncode != 0:
        print(f"rg error: {result.stderr.strip()}", file=sys.stderr)
        sys.exit(1)

    # Exclude subagent session files — they're ephemeral and not resumable
    return [p for p in result.stdout.strip().split("\n") if p and "/subagents/" not in p]


def main():
    args = parse_args()
    check_dependencies()

    matched_files = rg_find_sessions(args.query)
    if not matched_files:
        print(f"No sessions matching '{args.query}'")
        sys.exit(0)

    project_filter = os.getcwd() if args.project else None
    sessions = extract_matches(matched_files, args.query, project_filter)

    if not sessions:
        print(f"No sessions matching '{args.query}'")
        sys.exit(0)

    # Build fzf input: id \t proj_dir \t display \t cwd
    lines = []
    for s in sessions:
        proj_short = os.path.basename(s["cwd"]) if s["cwd"] != "?" else "?"
        slug_part = f"  ({s['slug']})" if s["slug"] else ""
        display = f"[{s['ts']}] {proj_short}{slug_part}  --  {s['snippet']}"
        line = f"{s['id']}\t{s['proj_dir']}\t{display}\t{s['cwd']}"
        lines.append(line)

    fzf_input = "\n".join(lines)

    # Build fzf command
    fzf_cmd = [
        "fzf",
        "--delimiter", "\t",
        "--with-nth", "3",
        "--ansi",
        "--no-sort",
        "--header", f"Sessions matching '{args.query}' | Enter=resume | Ctrl-P=toggle preview | Esc=cancel",
        "--bind", "ctrl-p:toggle-preview",
        "--color", "header:#ff79c6,info:#8be9fd,pointer:#50fa7b,prompt:#bd93f9",
    ]

    # Add preview if claude-sessions is available
    preview_script = find_preview_script()
    if preview_script:
        fzf_cmd.extend([
            "--preview", f'"{preview_script}" --preview {{1}} {{2}}',
            "--preview-window", "right:60%:wrap",
        ])

    try:
        # capture_output=True is intentional: fzf renders its TUI via /dev/tty
        # directly, not through stdout/stderr. We capture stdout only to read
        # the selected line after fzf exits. Do not remove capture_output.
        result = subprocess.run(
            fzf_cmd,
            input=fzf_input,
            text=True,
            capture_output=True,
        )

        if result.returncode == 0 and result.stdout.strip():
            selected = result.stdout.strip().split("\t")
            session_id = selected[0]
            session_cwd = selected[3] if len(selected) > 3 else None

            # cd to session's original directory if it exists
            if session_cwd and os.path.isdir(session_cwd):
                os.chdir(session_cwd)
                print(f"\033[2mcd {session_cwd}\033[0m")

            os.execvp("claude", ["claude", "--resume", session_id])
        else:
            sys.exit(0)

    except FileNotFoundError:
        print("fzf not found. Install: brew install fzf", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
